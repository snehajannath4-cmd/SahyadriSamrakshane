<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Green Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/forest_dark"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlertTypeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report Alert"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill the details below"
                android:textColor="@color/text_light_green"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Description Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <!-- Description Input -->
            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Describe what you see..."
                android:background="@drawable/input_bg"
                android:padding="10dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textSize="13sp" />

            <!-- GPS Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS Location"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <!-- GPS Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_light_green"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvGpsCoordinates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fetching GPS location..."
                    android:textColor="@color/forest_dark"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Photo Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photo Evidence"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <!-- Photo Button -->
            <LinearLayout
                android:id="@+id/btnTakePhoto"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/photo_border"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to capture photo"
                    android:textColor="@color/forest_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Photo Preview -->
            <!-- Photo Preview -->
            <ImageView
                android:id="@+id/ivPhotoPreview"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:background="@drawable/photo_border" />

            <TextView
                android:id="@+id/tvPhotoStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Photo captured!"
                android:textColor="@color/forest_dark"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginTop="6dp" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Submit Alert"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/forest_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="24dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>