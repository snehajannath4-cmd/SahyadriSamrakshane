<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_white">

    <!-- Top Green Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/forest_dark"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 Eco Education"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Learn to protect the Ghats"
            android:textColor="@color/text_light_green"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tip 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_light_green"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 Stay on marked trails"
                    android:textColor="@color/forest_dark"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Going off-trail disturbs wildlife habitats and causes soil erosion in fragile zones."
                    android:textColor="@color/forest_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Tip 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_light_green"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 If you see smoke"
                    android:textColor="@color/forest_dark"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Move upwind immediately. Report using this app. Never try to fight a forest fire alone."
                    android:textColor="@color/forest_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Tip 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_light_green"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐆 Wildlife sighting?"
                    android:textColor="@color/forest_dark"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep distance, stay quiet, do not feed. Report to help track animal movement safely."
                    android:textColor="@color/forest_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Tip 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_light_green"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚯 No plastic in forests"
                    android:textColor="@color/forest_dark"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carry all waste back with you. Plastic bags and bottles harm animals and block water flow."
                    android:textColor="@color/forest_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Tip 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_light_green"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪓 Report illegal cutting"
                    android:textColor="@color/forest_dark"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="If you see anyone cutting trees without permission, report immediately using this app."
                    android:textColor="@color/forest_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>